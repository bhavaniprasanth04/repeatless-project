# ==============================================================================
# REPEATLESS GMAIL AGENT - ENVIRONMENT VARIABLES EXAMPLE
# ==============================================================================
# Copy this file to '.env' inside the /backend and /frontend directories respectively
# and fill in your custom values. Do NOT commit actual secrets to version control.

# ------------------------------------------------------------------------------
# BACKEND SERVICES CONFIGURATION (Save inside /backend/.env)
# ------------------------------------------------------------------------------

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Google OAuth Integration (Used for authenticating Gmail inbox access)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Supabase DB Integration (Used for storing synchronized threads, emails, and statuses)
SUPABASE_URL=https://your_project_id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_public_key_here

# AI Engine Credentials (Used for content parsing, classification, and summarization)
GEMINI_API_KEY=your_gemini_api_key_here
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here

# n8n Automation Webhooks (Direct connection to workflows handling Gmail events and agents)
N8N_SYNC_WEBHOOK_URL=https://your-n8n-instance.com/webhook/email-sync
N8N_CHAT_WEBHOOK_URL=https://your-n8n-instance.com/webhook/chat-query
N8N_COMPOSE_WEBHOOK_URL=https://your-n8n-instance.com/webhook/email-compose
N8N_REPLY_WEBHOOK_URL=https://your-n8n-instance.com/webhook/email-reply

# ------------------------------------------------------------------------------
# FRONTEND SERVICES CONFIGURATION (Save inside /frontend/.env)
# ------------------------------------------------------------------------------

# API connection endpoint pointing to the Express server
VITE_API_URL=http://localhost:5000/api

# Fallback webhooks for frontend direct routing (if needed)
VITE_N8N_CHAT_WEBHOOK_URL=https://your-n8n-instance.com/webhook/chat-query
VITE_N8N_COMPOSE_WEBHOOK_URL=https://your-n8n-instance.com/webhook/email-compose
VITE_N8N_REPLY_WEBHOOK_URL=https://your-n8n-instance.com/webhook/email-reply
